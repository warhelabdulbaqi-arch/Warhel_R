SET UTF-8
LANG ku_IQ

# ---------------------------------------------------------------------------
# Character Set & Alphabet Definition
# ---------------------------------------------------------------------------
TRY ه‌ەەائبپتجچحخد ژژەـه‌هرڕزژسشعغفڤقکگڵلمنوۆهەیێە‌

WORDCHARS ئ ا ب پ ت ج چ ح خ د ر ز ژژژ س ش ع غ ف ڤ ق ک گ ل م ن و ه ه‌ ی ێ ۆ
# ---------------------------------------------------------------------------
# Input Conversion (Normalization for Arabic/Persian/Legacy Keyboards)
# ---------------------------------------------------------------------------
ICONV 15
ICONV ه ە
ICONV ہ ە
ICONV ە ہ
ICONV ه‌ ە
ICONV ژ ژ
ICONV ك ک
ICONV ی ی
ICONV ی ی
ICONV ی ێ
ICONV رٚ ڕ
ICONV لٚ ڵ
ICONV ڤ v
ICONV ۆ و
ICONV ‌ 0
ICONV ـ 0

# ---------------------------------------------------------------------------
# Replacement Table (Common Typo Suggestions)
# ---------------------------------------------------------------------------
REP 10
REP ه ە
REP ە ه
REP ی ێ
REP ێ ی
REP ف ڤ
REP ڤ ف
REP ڕ ر
REP ڵ ل
REP و ۆ
REP ۆ و

# ---------------------------------------------------------------------------
# Character Mapping (Treating similar characters as equivalent in search)
# ---------------------------------------------------------------------------
MAP 4
MAP (ەهہ)
MAP (یێیی)
MAP (کك)
MAP (وۆ)

# ---------------------------------------------------------------------------
# Replacement Table (Common Typo Suggestions)
# ---------------------------------------------------------------------------
REP 4
REP لگەل ل_گەل
REP ژبەر ژ_بەر
REP لدویڤ ل_دویڤ
REP لسەر ل_سەر
# ---------------------------------------------------------------------------
# Ignore Kashida/Tatweel (Common in Arabic typing)
# ---------------------------------------------------------------------------
IGNORE ـ

PFX 1 Y 2
PFX 1 0 ڤە .
PFX 1 0 ڤە .

PFX 2 Y 1
PFX 2 0 دا .

